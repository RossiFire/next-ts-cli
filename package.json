{
  "name": "next-ts-cli",
  "version": "1.0.16",
  "description": "Create production-ready web application with the Next.js",
  "author": "Daniele Rossino <daniele.rossino10@gmail.com>",
  "maintainers": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RossiFire/next-ts-cli.git"
  },
  "keywords": [
    "next-ts-cli",
    "next.js",
    "saas",
    "template",
    "supabase",
    "tailwind",
    "typescript"
  ],
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
    "next-ts-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.12.0",
  "scripts": {
    "typecheck": "tsc",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules",
    "start": "node dist/index.js",
    "lint": "biome check",
    "format": "biome format --write",
    "lint:fix": "biome check --write",
    "release": "changeset version",
    "pub:release": "npm build && npm publish"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.139",
    "@clack/core": "^1.1.0",
