    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "gradient-string": "^3.0.0",
    "ora": "9.3.0",
    "sort-package-json": "^3.6.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
