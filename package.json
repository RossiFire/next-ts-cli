    "@tailwindcss/postcss": "^4.2.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.5.0",
    "better-auth": "^1.5.6",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "mysql2": "^3.20.0",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.2.2",
